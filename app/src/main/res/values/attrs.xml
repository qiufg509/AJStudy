<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="DynamicToolbar">
        <attr name="mode" format="enum">
            <enum name="title_ai" value="0" />
            <enum name="title_only" value="1" />
            <enum name="back_only" value="2" />
            <enum name="back_title" value="3" />
            <enum name="back_title_share" value="4" />
            <enum name="menu_title_close" value="5" />
            <enum name="gone" value="6" />
        </attr>
    </declare-styleable>
    <declare-styleable name="RoundedFrameLayout">
        <attr name="corner_radius" format="dimension" />
    </declare-styleable>
    <declare-styleable name="BounceScrollView">
        <!-- 回弹强度 -->
        <attr name="bounceStrength" format="float" />
        <!-- 最大越界距离 -->
        <attr name="maxOverScroll" format="dimension" />
        <!-- 越界阻尼系数 -->
        <attr name="overScrollDamping" format="float" />
    </declare-styleable>
    <declare-styleable name="LuckyWheel">
        <attr name="iconSize" format="dimension" />
        <attr name="centerBtn" format="reference" />
        <attr name="centerBtnSize" format="dimension" />
        <attr name="isTowardCenter" format="boolean" />
    </declare-styleable>
</resources>