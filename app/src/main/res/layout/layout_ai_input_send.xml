<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_input_send"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/activity_horizontal_margin_m"
    android:layout_marginBottom="@dimen/activity_horizontal_margin_m"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="@dimen/radius_xl"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="false"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ai_input_send_bg"
        android:paddingStart="@dimen/activity_horizontal_margin_l"
        android:paddingEnd="0dp">

        <!-- 无边框输入框 -->
        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:autofillHints=""
            android:background="@null"
            android:hint="@string/ai_hint"
            android:inputType="textMultiLine"
            android:maxLines="5"
            android:paddingVertical="@dimen/activity_vertical_margin_s"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_send"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 发送按钮 -->
        <ImageView
            android:id="@+id/btn_send"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="@dimen/activity_horizontal_margin_m"
            android:contentDescription="@string/ai_send"
            android:scaleType="centerInside"
            android:tint="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/et_message"
            app:srcCompat="@drawable/ic_btn_send"
            app:tint="@null" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>